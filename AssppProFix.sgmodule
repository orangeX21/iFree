[Script]
AssppProFix = type=http-response, pattern=^https:\/\/api\.timbrd\.com\/apple\/app-version\/index\.php\?id=\d+$, script-path=https://raw.githubusercontent.com/orangeX21/iFree/main/Asspp_Pro.js, requires-body=true, timeout=60

[MITM]
hostname = %APPEND% api.timbrd.com